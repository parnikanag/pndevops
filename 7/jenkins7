pipeline 
{
    agent any
    
    tools 
   {
        maven 'M3' 
    }

    stages 
   {
        stage('Checkout') 
        {
            steps 
           { 
               git url:'https://github.com/parnikanag/maven-demo' , branch: 'main'
            }
        }
        stage('Build') 
        {
            steps 
           { 
                sh 'mvn clean package -DskipTests' 
            }
        }
        stage('Test') 
       {
            steps 
           { 
                sh 'mvn test -Dmaven.test.failure.ignore=true' 
            }
        }
    }

    post
    {
        always 
       {
            junit 'target/surefire-reports/*.xml'
        }
    }
}
