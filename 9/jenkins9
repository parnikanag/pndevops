pipeline 
{
    agent any
    
    parameters 
   {
        string(name: 'BRANCH_NAME', defaultValue: 'main', description: 'Git branch to build')
    }
    
    tools
   {
        maven 'M3' 
    }

    stages 
   {
        stage('Checkout') 
       {
            steps 
           {
                git branch: params.BRANCH_NAME, url: 'https://github.com/parnikanag/parameterized-build'
            }
        }
        stage('Build') 
       {
            steps 
           { 
                sh 'mvn clean package -DskipTests' 
            }
        }
        stage('Test') 
        {
            steps 
           { 
                sh 'mvn test -Dmaven.test.failure.ignore=true' 
            }
        }
    }
}